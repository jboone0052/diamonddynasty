{
  "name": "baseball-sim-starter",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0"
  },
  "scripts": {
    "dev": "npm run dev -w apps/game-app",
    "web": "npm run web -w apps/game-app",
    "ios": "npm run ios -w apps/game-app",
    "android": "npm run android -w apps/game-app",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test -w packages/game-core"
  },
  "dependencies": {
    "is-arrayish": "^0.3.4"
  }
}
